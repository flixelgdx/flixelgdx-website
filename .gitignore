# Build artefacts produced by scripts/build-api.sh + Gradle
build/
.gradle/

# Generated API markdown. Run `./scripts/build-api.sh` to populate
# locally. site/api/index.md is hand-written and IS tracked (see
# the corresponding negation rule in site/.gitignore).
site/api/**
!site/api/index.md

# Docusaurus
site/.docusaurus/
site/build/
site/node_modules/
site/.cache-loader/

# OS / editor noise
.DS_Store
*.log
.idea/
.vscode/
*.iml
